# Discord bot token
# Obtain it from https://discord.com/developers/applications
DISCORD_TOKEN=your_token_here

# Optional command prefix for text commands
COMMAND_PREFIX=!

# Debug mode flag
DEBUG=False

# Server IDs for private commands (comma separated)
# Example: PRIVATE_SERVER_IDS=123456789012345678,987654321098765432
# Leave empty to skip private commands
PRIVATE_SERVER_IDS=
